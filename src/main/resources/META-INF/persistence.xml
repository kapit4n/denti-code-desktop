<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">
    <persistence-unit name="denti-code" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.denticode.desktop.domain.model.User</class>
        <class>com.denticode.desktop.domain.model.Doctor</class>
        <class>com.denticode.desktop.domain.model.Patient</class>
        <class>com.denticode.desktop.domain.model.Appointment</class>
        <class>com.denticode.desktop.domain.model.PerformedAction</class>
        <class>com.denticode.desktop.domain.model.ProcedureType</class>
        <class>com.denticode.desktop.domain.model.TreatmentFacility</class>
        <class>com.denticode.desktop.domain.model.Consultory</class>
        <class>com.denticode.desktop.domain.model.MaterialInventoryLine</class>
        <class>com.denticode.desktop.domain.model.InventoryMovement</class>
        <class>com.denticode.desktop.domain.model.Payment</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="hibernate.archive.autodetection" value="class"/>
        </properties>
    </persistence-unit>
</persistence>
